          {icon:"💼",title:"LinkedIn que trabalha por ti 24/7",points:["Aparecer nas pesquisas dos recrutadores","Perfil que atrai convites espontâneos","Conteúdo que te posiciona como especialista"]},
          {icon:"🎯",title:"Entrevistas que te colocam no topo",points:["Método STAR para qualquer pergunta","Linguagem corporal e comunicação não-verbal","Negociação salarial que te valoriza"]}
        ].map(b=>(
          <div key={b.title} className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div className="text-3xl mb-3">{b.icon}</div>
            <h3 className="font-bold text-slate-800 mb-3">{b.title}</h3>
            <ul className="space-y-2">
              {b.points.map(p=>(
                <li key={p} className="flex items-start gap-2 text-sm text-slate-600">
                  <span className="text-green-500 font-bold mt-0.5">✓</span>{p}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div className="text-center mt-10">
        <Btn onClick={onStart} variant="navy" size="lg">Quero começar agora →</Btn>
      </div>
    </div>
  </section>
);

