};

/* AI Coach */
const CoachPage = ({user}) => {
  const [msgs,setMsgs] = useState(()=>LS.get('nj_chat',[]));
  const [input,setInput] = useState('');
  const [loading,setLoading] = useState(false);
  const [apiKey,setApiKey] = useState(()=>LS.get('nj_apikey',''));
  const [showKeyInput,setShowKeyInput] = useState(false);
  const bottomRef = useRef(null);

  useEffect(()=>{
    LS.set('nj_chat',msgs.slice(-10));
    bottomRef.current?.scrollIntoView({behavior:'smooth'});
  },[msgs]);

  const send = async () => {
    const text = input.trim();
    if(!text||loading) return;
    if(!apiKey){setShowKeyInput(true);return;}
    const userMsg = {role:'user',content:text,ts:Date.now()};
    setMsgs(m=>[...m,userMsg]);
    setInput('');
    setLoading(true);
    try {
      const history = [...msgs.slice(-8),userMsg];
      const res = await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{
          'Content-Type':'application/json',
          'x-api-key':apiKey,
          'anthropic-version':'2023-06-01',
          'anthropic-dangerous-allow-cors':'true'
        },
        body:JSON.stringify({
          model:'claude-sonnet-4-6',
          max_tokens:1024,
          system:'És um coach de carreira especialista em ajudar pessoas a conseguir emprego em Portugal e no Brasil. Dás conselhos práticos, diretos e motivadores. Respondes sempre em português. Mantém as respostas concisas e accionáveis.',
          messages:history.map(m=>({role:m.role,content:m.content}))
        })
      });
      if(!res.ok){const e=await res.json();throw new Error(e.error?.message||`Erro ${res.status}`);}
      const data = await res.json();
      setMsgs(m=>[...m,{role:'assistant',content:data.content[0].text,ts:Date.now()}]);
    } catch(e){
      setMsgs(m=>[...m,{role:'assistant',content:`⚠️ Erro: ${e.message}. Verifica a tua API key nas definições.`,ts:Date.now()}]);
    }
    setLoading(false);
  };

  const SUGG = ["Como posso melhorar o meu CV?","Que perguntas podem fazer numa entrevista?","Como negociar o salário?","Como abordar recrutadores no LinkedIn?"];

  return (
    <div className="flex flex-col h-[calc(100vh-0px)] fade-in">
      <div className="p-5 border-b border-slate-100 bg-white flex items-center justify-between">
        <div>
          <h1 className="text-xl font-black text-slate-800">Coach IA 🤖</h1>
          <p className="text-slate-400 text-xs mt-0.5">Especialista em carreiras · sempre disponível</p>
        </div>
        <div className="flex items-center gap-2">
          {apiKey && <span className="text-xs text-green-600 bg-green-50 px-2 py-1 rounded-full">● Conectado</span>}
          <button onClick={()=>setShowKeyInput(v=>!v)} className="text-slate-400 hover:text-slate-600 text-sm">⚙️</button>
        </div>
      </div>

      {showKeyInput && (
        <div className="m-4 p-4 bg-blue-50 border border-blue-200 rounded-xl">
          <p className="text-blue-800 text-xs font-semibold mb-2">Chave da API Anthropic</p>
          <div className="flex gap-2">
            <input type="password" value={apiKey} onChange={e=>setApiKey(e.target.value)}
              placeholder="sk-ant-..." className="flex-1 px-3 py-2 text-sm border border-blue-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400"/>
            <Btn size="sm" onClick={()=>{LS.set('nj_apikey',apiKey);setShowKeyInput(false);}}>Guardar</Btn>
          </div>
          <p className="text-blue-600 text-xs mt-2">A tua chave é guardada localmente e nunca partilhada. Obtém a tua em console.anthropic.com</p>
        </div>
      )}

      <div className="flex-1 overflow-y-auto p-4 space-y-3">
        {msgs.length===0 && (
          <div className="text-center py-10">
            <div className="text-5xl mb-4">🤖</div>
            <h3 className="font-bold text-slate-700 mb-2">O teu Coach de Carreira pessoal</h3>
            <p className="text-slate-400 text-sm mb-6 max-w-xs mx-auto">Faz qualquer pergunta sobre CV, entrevistas, networking ou estratégia de carreira.</p>
            {!apiKey && (
              <div className="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-700 max-w-sm mx-auto mb-6">
                ⚠️ Adiciona a tua API key da Anthropic para começar a conversar.
                <button onClick={()=>setShowKeyInput(true)} className="block mt-2 text-amber-800 font-semibold underline">Configurar agora</button>
              </div>
            )}
            <div className="grid grid-cols-2 gap-2 max-w-sm mx-auto">
              {SUGG.map(s=>(
                <button key={s} onClick={()=>setInput(s)}
                  className="text-left text-xs bg-white border border-slate-200 rounded-xl p-3 hover:border-blue-300 hover:bg-blue-50 transition-all text-slate-600">
                  {s}
                </button>
              ))}
            </div>
          </div>
        )}
        {msgs.map((m,i)=>(
          <div key={i} className={`chat-msg flex ${m.role==='user'?'justify-end':''}`}>
            {m.role==='assistant' && (
              <div className="w-7 h-7 bg-blue-600 rounded-full flex items-center justify-center text-xs mr-2 flex-shrink-0 mt-1">🤖</div>
            )}
            <div className={`max-w-[80%] px-4 py-3 rounded-2xl text-sm leading-relaxed
              ${m.role==='user'?'bg-blue-600 text-white rounded-tr-sm':'bg-white border border-slate-100 text-slate-700 rounded-tl-sm shadow-sm'}`}>
              {m.content}
            </div>
          </div>
        ))}
        {loading && (
          <div className="flex items-center gap-2">
            <div className="w-7 h-7 bg-blue-600 rounded-full flex items-center justify-center text-xs flex-shrink-0">🤖</div>
            <div className="bg-white border border-slate-100 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm">
              <div className="dot-typing"><span/><span/><span/></div>
            </div>
          </div>
        )}
        <div ref={bottomRef}/>
      </div>

      <div className="p-4 border-t border-slate-100 bg-white">
        <div className="flex gap-2">
          <input value={input} onChange={e=>setInput(e.target.value)}
            onKeyDown={e=>e.key==='Enter'&&!e.shiftKey&&send()}
            placeholder="Faz uma pergunta sobre carreira..."
            className="flex-1 px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
          <Btn onClick={send} disabled={loading||!input.trim()} variant="primary" size="md">
            {loading?<Spinner size="w-4 h-4" color="border-white"/>:'→'}
          </Btn>
        </div>
        {msgs.length>0 && (
          <button onClick={()=>{setMsgs([]);LS.del('nj_chat');}} className="text-xs text-slate-400 hover:text-slate-600 mt-2">Limpar conversa</button>
        )}
      </div>
    </div>
  );
};

/* Settings */
const SettingsPage = ({user,setUser,onLogout}) => {
  const [showPayment,setShowPayment] = useState(false);
  const [payDone,setPayDone] = useState(false);
  const [name,setName] = useState(user.name);
  const [saved,setSaved] = useState(false);

  const saveName = () => {
    const u = {...user,name:name.trim()||user.name};
    LS.set('nj_user',u);setUser(u);setSaved(true);
    setTimeout(()=>setSaved(false),2000);
  };

  const handleUpgrade = () => {
    setShowPayment(false);setPayDone(true);
    const u={...user,plan:'pro'};LS.set('nj_user',u);setUser(u);
    setTimeout(()=>setPayDone(false),5000);
  };

  return (
    <div className="p-6 fade-in max-w-xl">
      <h1 className="text-2xl font-black text-slate-800 mb-6">Definições</h1>

      {payDone && (
        <div className="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl text-green-800 font-medium text-sm">
          🎉 Pagamento processado com sucesso! Plano Pro ativado. Aproveita o acesso total!
        </div>
      )}

      <div className="space-y-4">
        <div className="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
          <h2 className="font-bold text-slate-700 mb-4">Informação da conta</h2>
          <div className="space-y-3">
            <div>
              <label className="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Nome</label>
              <div className="flex gap-2">
                <input value={name} onChange={e=>setName(e.target.value)}
                  className="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
                <Btn onClick={saveName} variant="secondary" size="sm">{saved?'✓ Guardado':'Guardar'}</Btn>
              </div>
            </div>
            <div>
              <label className="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Email</label>
              <div className="px-3 py-2 bg-slate-50 border border-slate-100 rounded-lg text-sm text-slate-500">{user.email}</div>
            </div>
          </div>
        </div>

        <div className="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
          <h2 className="font-bold text-slate-700 mb-4">Plano atual</h2>
          <div className={`rounded-xl p-4 mb-4 ${user.plan==='pro'?'bg-amber-50 border border-amber-200':'bg-slate-50 border border-slate-200'}`}>
            <div className="flex items-center justify-between">
              <div>
                <div className={`font-bold ${user.plan==='pro'?'text-amber-700':'text-slate-700'}`}>
                  {user.plan==='pro'?'⭐ Plano Pro':'Plano Grátis'}
                </div>
                <div className={`text-sm ${user.plan==='pro'?'text-amber-600':'text-slate-500'}`}>
                  {user.plan==='pro'?'Acesso total a todos os módulos e templates':'Acesso a 2 módulos e 3 templates'}
                </div>
              </div>
              {user.plan==='pro' && <Badge className="bg-amber-400/20 text-amber-700">Ativo</Badge>}
            </div>
          </div>
          {user.plan!=='pro' && (
            <Btn onClick={()=>setShowPayment(true)} variant="primary" size="md" className="w-full">
              ⭐ Fazer upgrade para Pro — €9.99/mês
            </Btn>
          )}
          {user.plan==='pro' && (
            <button className="text-sm text-slate-400 hover:text-red-500 transition-colors">Cancelar subscrição</button>
          )}
        </div>

        <div className="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
          <h2 className="font-bold text-slate-700 mb-4">Dados</h2>
          <button onClick={()=>{LS.del('nj_progress');window.location.reload();}}
            className="text-sm text-slate-500 hover:text-red-500 transition-colors">
            Reiniciar progresso das lições
          </button>
        </div>

        <Btn onClick={onLogout} variant="danger" size="md">Terminar sessão</Btn>
      </div>

      <Modal open={showPayment} onClose={()=>setShowPayment(false)} title="Upgrade para Pro">
        <div className="space-y-4">
          <div className="bg-blue-50 rounded-xl p-4 text-center">
            <div className="text-3xl mb-2">⭐</div>
            <div className="font-bold text-slate-800 text-lg">Plano Pro</div>
            <div className="text-3xl font-black text-blue-600 mt-1">€9.99<span className="text-base font-normal text-slate-500">/mês</span></div>
          </div>
          <ul className="space-y-2 text-sm text-slate-600">
            {["Todos os 5 módulos desbloqueados","Todos os templates premium","Coach IA ilimitado","Comunidade exclusiva","Suporte prioritário","Cancela a qualquer momento"].map(f=>(
              <li key={f} className="flex items-center gap-2"><span className="text-green-500">✓</span>{f}</li>
            ))}
          </ul>
          <div className="space-y-2">
            <input placeholder="Número do cartão" className="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" defaultValue="4242 4242 4242 4242"/>
            <div className="grid grid-cols-2 gap-2">
              <input placeholder="MM/AA" className="px-3 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none" defaultValue="12/27"/>
              <input placeholder="CVV" className="px-3 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none" defaultValue="123"/>
            </div>
          </div>
          <Btn onClick={handleUpgrade} variant="primary" size="md" className="w-full">
            Pagar €9.99/mês →
          </Btn>
          <p className="text-center text-xs text-slate-400">Pagamento seguro · Cancela a qualquer momento</p>
        </div>
      </Modal>
    </div>
  );
};

/* Dashboard wrapper */
const Dashboard = ({user:initUser,onLogout}) => {
  const [user,setUser] = useState(initUser);
  const [tab,setTab] = useState('home');
  const [sidebarOpen,setSidebarOpen] = useState(false);
  const [selectedModule,setSelectedModule] = useState(null);
  const [selectedLesson,setSelectedLesson] = useState(null);
  const [progress,setProgress] = useState(()=>LS.get('nj_progress',{}));

  useEffect(()=>LS.set('nj_progress',progress),[progress]);

  const logout = () => {LS.del('nj_user');onLogout();};

  const goToTab = (t) => {setTab(t);if(t!=='modules'){setSelectedModule(null);setSelectedLesson(null);}};

  const sidebarProps = {tab,setTab:goToTab,user,onLogout:logout};

  return (
    <div className="flex h-screen overflow-hidden bg-slate-50">
      {/* Desktop sidebar */}
      <div className="hidden md:block flex-shrink-0">
        <Sidebar {...sidebarProps}/>
      </div>

      {/* Mobile sidebar */}
      {sidebarOpen && (
        <>
          <div className="fixed inset-0 bg-black/40 z-40 md:hidden" onClick={()=>setSidebarOpen(false)}/>
          <Sidebar {...sidebarProps} mobile onClose={()=>setSidebarOpen(false)}/>
        </>
      )}

      <div className="flex-1 flex flex-col min-w-0 overflow-hidden">
        {/* Mobile top bar */}
        <div className="md:hidden flex items-center gap-3 px-4 py-3 bg-white border-b border-slate-100 sticky top-0 z-30">
          <button onClick={()=>setSidebarOpen(true)} className="text-slate-600 text-xl">☰</button>
          <div className="flex items-center gap-2">
            <div className="w-6 h-6 bg-blue-600 rounded flex items-center justify-center text-white font-black text-xs">NJ</div>
            <span className="font-black text-[#1e3a5f] text-sm">NailJob</span>
          </div>
        </div>

        <main className="flex-1 overflow-y-auto">
          {tab==='home' && <DashHome user={user} progress={progress} setTab={goToTab} setSelectedModule={setSelectedModule} setSelectedLesson={setSelectedLesson}/>}
          {tab==='modules' && <ModulesPage user={user} progress={progress} setProgress={setProgress} selectedModule={selectedModule} selectedLesson={selectedLesson} setSelectedModule={setSelectedModule} setSelectedLesson={setSelectedLesson}/>}
          {tab==='templates' && <TemplatesPage user={user}/>}
          {tab==='community' && <CommunityPage/>}
          {tab==='coach' && <CoachPage user={user}/>}
          {tab==='settings' && <SettingsPage user={user} setUser={setUser} onLogout={logout}/>}
        </main>
      </div>
    </div>
  );
};

/* ===================== APP ===================== */

const App = () => {
  const [page,setPage] = useState('landing');
  const [authMode,setAuthMode] = useState('register');
  const [defaultPlan,setDefaultPlan] = useState('free');
  const [user,setUser] = useState(()=>LS.get('nj_user',null));

  useEffect(()=>{if(user)setPage('dashboard');},[]);

  const goAuth = (plan) => {
    setDefaultPlan(typeof plan==='string'?plan:'free');
    setAuthMode('register');
    setPage('auth');
  };

  const goLogin = () => {setAuthMode('login');setPage('auth');};

  const onAuth = (u) => {setUser(u);setPage('dashboard');};
  const onLogout = () => {setUser(null);setPage('landing');};

  if(page==='dashboard'&&user) return <Dashboard user={user} onLogout={onLogout}/>;
  if(page==='auth') return <AuthPage mode={authMode} defaultPlan={defaultPlan} onAuth={onAuth} onBack={()=>setPage('landing')}/>;
  return <LandingPage onStart={goAuth} onLogin={goLogin}/>;
};

const rootEl = document.getElementById('root');
rootEl.innerHTML = '';
ReactDOM.createRoot(rootEl).render(<App/>);
  </script>
</body>

</html>
