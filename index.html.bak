.prose pre{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:1rem;overflow-x:auto;margin:.75rem 0}
.prose pre code{background:none;padding:0;color:#334155;font-size:.85rem}
.prose blockquote{border-left:3px solid #2563eb;padding-left:1rem;color:#64748b;font-style:italic;margin:.75rem 0;background:#f0f7ff;border-radius:0 6px 6px 0;padding:.75rem 1rem}
.chat-msg{animation:slideUp .25s ease-out}
@keyframes slideUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.dot-typing span{display:inline-block;width:7px;height:7px;border-radius:50%;background:#94a3b8;margin:0 2px;animation:dotB 1.3s infinite ease-in-out}
.dot-typing span:nth-child(2){animation-delay:.2s}
.dot-typing span:nth-child(3){animation-delay:.4s}
@keyframes dotB{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.fade-in{animation:fadeIn .3s ease-in-out}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
</style>
