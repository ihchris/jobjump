.prose h1{font-size:1.5rem;font-weight:800;color:#1e3a5f;margin:1.25rem 0 .75rem}
.prose h2{font-size:1.15rem;font-weight:700;color:#1e3a5f;margin:1.2rem 0 .5rem;padding-bottom:.3rem;border-bottom:2px solid #e2e8f0}
.prose h3{font-size:1rem;font-weight:600;color:#334155;margin:.9rem 0 .4rem}
.prose p{color:#475569;line-height:1.75;margin-bottom:.75rem}
